# Vercel Preview / staging — set in Vercel → Settings → Environment Variables → Preview

NEXT_PUBLIC_COMFYSKILL_ENV=staging
NEXT_PUBLIC_API_URL=https://YOUR-STAGING-API.up.railway.app

NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=comfy-skill-web.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=comfy-skill-web
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=comfy-skill-web.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_APP_ID=REPLACE_ME
