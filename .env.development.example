# Local development — copy to `.env.local` (gitignored)
# NEXT_PUBLIC_* are exposed to the browser; never put Stripe secret or Firebase Admin JSON here.

NEXT_PUBLIC_COMFYSKILL_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000

# Firebase Web SDK (public client config — from Firebase Console → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=comfy-skill-web.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=comfy-skill-web
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=comfy-skill-web.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_APP_ID=REPLACE_ME

# Stripe.js public key (pk_test_... from Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# E2E only — do not commit real passwords; use CI secrets
E2E_TEST_USER_PASSWORD=REPLACE_ME
